{
  "$schema": "https://opencode.ai/config.json",
  "model": "f5ai/claude-sonnet-4-6",
  "agent": {
    "build":      { "model": "f5ai/claude-sonnet-4-6" },
    "plan":       { "model": "f5ai/claude-opus-4-8" },
    "explore":    { "model": "f5ai/claude-haiku-4-5" },
    "scout":      { "model": "f5ai/claude-haiku-4-5" },
    "general":    { "model": "f5ai/claude-sonnet-4-6" },
    "compaction": { "model": "f5ai/DeepSeek-V4-Flash" },
    "title":      { "model": "f5ai/gpt-5-nano" },

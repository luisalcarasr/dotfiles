# Mako Notification Configuration
# Inspired by wofi theme - GitHub Dark color scheme

# Layout
width=350
height=120
margin=10
padding=12
border-size=1
border-radius=10

# Position
anchor=top-right
default-timeout=5000
ignore-timeout=0
max-visible=5

# Colors - GitHub Dark theme matching wofi
background-color=#0d1117f2
text-color=#e6edf3
border-color=#30363d

# Progress bar
progress-color=over #58a6ff

# Icons
icon-path=/usr/share/icons/Papirus-Dark
icons=1
max-icon-size=48

# Font
font=Adwaita Sans 12

# Spacing
markup=1
format=<b>%s</b>\n%b

# Urgency Levels
[urgency=low]
border-color=#30363d
background-color=#0d1117f2
text-color=#8b949e

[urgency=normal]
border-color=#30363d
background-color=#0d1117f2
text-color=#e6edf3

[urgency=critical]
border-color=#f85149
background-color=#0d1117f2
text-color=#ffffff
default-timeout=0

# Grouped notifications
group-by=app-name

# Actions
actions=1

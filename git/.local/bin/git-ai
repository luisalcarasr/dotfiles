#!/usr/bin/env python3
"""git-ai — AI-powered git helpers using a local ollama model.

Usage: git ai commit [--model <model>] [--dry-run]
"""

import re
import subprocess
import sys
from math import ceil, log

# ── constants ─────────────────────────────────────────────────────────────────

COMMIT_REGEX = re.compile(
    r"^(feat|fix|build|chore|ci|docs|style|refactor|perf|test)"
    r"(\([a-z0-9._/-]+\))?(!)?: .+$"
)
DEFAULT_MODEL = "codellama"
MAX_DIFF_LINES = 300
SUMMARY_MAX_CHARS = 75

# ── helpers ───────────────────────────────────────────────────────────────────

def die(msg: str) -> None:
    print(f"git-ai: error: {msg}", file=sys.stderr)
    sys.exit(1)


def strip_ansi(text: str) -> str:
    return re.sub(r"\x1b\[[0-9;?]*[a-zA-Z]", "", text)


def get_repo_root() -> str:
    result = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        capture_output=True,
        text=True,
        check=True,
    )
    return result.stdout.strip()


def run_ollama(model: str, prompt: str) -> str:
    try:
        result = subprocess.run(
            ["ollama", "run", model, "--nowordwrap", prompt],
            capture_output=True,
            text=True,
        )
    except FileNotFoundError:
        die("ollama not found in PATH")

    if result.returncode != 0:
        die("ollama failed — is it running? (ollama serve)")

    return strip_ansi(result.stdout).strip()

# ── step 1: list staged files ─────────────────────────────────────────────────

def list_staged_files() -> list[str]:
    repo_root = get_repo_root()
    result = subprocess.run(
        ["git", "diff", "--cached", "--name-only", "--diff-filter=ACMRT"],
        capture_output=True,
        text=True,
        cwd=repo_root,
    )
    return [f for f in result.stdout.splitlines() if f]

# ── step 2: summarise each file diff ─────────────────────────────────────────

def summarise_file_diff(model: str, file: str) -> str | None:
    repo_root = get_repo_root()
    result = subprocess.run(
        ["git", "diff", "--cached", "--", file],
        capture_output=True,
        text=True,
        cwd=repo_root,
    )
    diff = result.stdout.strip()

    if not diff:
        return None

    lines = diff.splitlines()
    if len(lines) > MAX_DIFF_LINES:
        diff = "\n".join(lines[:MAX_DIFF_LINES]) + "\n... (diff truncated)"

    prompt = (
        f"You are a code analyst. Read the git diff below and reply with ONE single line of "
        f"plain text summarising what changed and why (infer intent). "
        f"Max {SUMMARY_MAX_CHARS} characters. No bullet, no prefix, no punctuation at the end, no newlines.\n\n"
        f"File: {file}\n"
        f"Git diff:\n{diff}\n\n"
        f"Summary:"
    )
    return run_ollama(model, prompt) or None

# ── step 3a: merge two summaries ─────────────────────────────────────────────

def merge_summaries(model: str, a: str, b: str) -> str:
    prompt = (
        f"You are a code analyst. Combine the two change summaries below into ONE single line of "
        f"plain text that captures the essence of both. "
        f"Max {SUMMARY_MAX_CHARS} characters. No bullet, no prefix, no punctuation at the end, no newlines.\n\n"
        f"Summary 1: {a}\n"
        f"Summary 2: {b}\n\n"
        f"Combined summary:"
    )
    return run_ollama(model, prompt)

# ── step 3b: binary-tree merge ────────────────────────────────────────────────

def binary_merge(model: str, summaries: list[str]) -> str:
    if len(summaries) == 1:
        return summaries[0]

    while len(summaries) > 1:
        next_round = []
        for i in range(0, len(summaries), 2):
            if i + 1 < len(summaries):
                next_round.append(merge_summaries(model, summaries[i], summaries[i + 1]))
            else:
                next_round.append(summaries[i])
        summaries = next_round

    return summaries[0]

# ── step 4: generate commit message ──────────────────────────────────────────

def generate_commit(model: str, summary: str) -> str:
    prompt = (
        "You are a git commit message generator. Output ONLY a single-line Conventional Commit message. "
        "No explanation, no markdown, no quotes, no code block, no newlines.\n\n"
        "Rules:\n"
        "- Format: <type>(<optional-scope>): <imperative description>\n"
        "- Types: feat, fix, build, chore, ci, docs, style, refactor, perf, test\n"
        "- Scope: short lowercase identifier (component, module, or file group). Omit if unclear.\n"
        "- Description: imperative mood, lowercase, no trailing period, max 68 chars after the prefix.\n"
        "- Total line must not exceed 72 characters. Count every character carefully before outputting — do NOT truncate or cut off mid-word.\n\n"
        f"Change summary:\n{summary}\n\n"
        "Conventional commit:"
    )
    return run_ollama(model, prompt)

# ── validate and clean commit message ────────────────────────────────────────

def validate_commit(raw: str) -> str | None:
    msg = raw.splitlines()[0] if raw.splitlines() else raw

    # Strip whitespace, backticks, and quotes
    msg = msg.strip().strip("`\"'").strip()

    # Strip leading "commit:", "message:", etc.
    msg = re.sub(r"(?i)^(commit message:?|message:?|output:?)\s*", "", msg).strip()

    # Lowercase first char of description
    m = re.match(r"^([a-z]+(\([^)]+\))?!?: )(.+)", msg)
    if m:
        prefix, _, desc = m.group(1), m.group(2), m.group(3)
        desc = desc[0].lower() + desc[1:]
        msg = prefix + desc

    # Strip trailing period
    msg = re.sub(r"\.$", "", msg)

    if COMMIT_REGEX.match(msg):
        return msg
    return None

# ── command: commit ───────────────────────────────────────────────────────────

def cmd_commit(args: list[str]) -> None:
    model = DEFAULT_MODEL
    dry_run = False

    i = 0
    while i < len(args):
        if args[i] in ("--model", "-m"):
            i += 1
            model = args[i]
        elif args[i] in ("--dry-run", "-n"):
            dry_run = True
        i += 1

    # Pre-flight checks
    result = subprocess.run(["ollama", "show", model], capture_output=True)
    if result.returncode != 0:
        die(f"model '{model}' not found — run: ollama pull {model}")

    # Step 1
    staged_files = list_staged_files()
    if not staged_files:
        die("no staged changes — run: git add <files>")

    file_count = len(staged_files)
    print(f"git-ai: {file_count} file(s) staged for commit", file=sys.stderr)

    # Step 2
    summaries = []
    for idx, file in enumerate(staged_files, 1):
        print(f"git-ai: [file {idx}/{file_count}] summarising {file}...", file=sys.stderr)
        summary = summarise_file_diff(model, file)
        if summary:
            summaries.append(summary)
        else:
            print(f"git-ai: [file {idx}/{file_count}] skipping {file} (empty or binary diff)", file=sys.stderr)

    if not summaries:
        die("no usable diffs found in staged files")

    # Step 3
    total = len(summaries)
    if total == 1:
        print("git-ai: [merge] single file — skipping merge step", file=sys.stderr)
        final_summary = summaries[0]
    else:
        rounds = ceil(log(total) / log(2))
        print(f"git-ai: [merge] reducing {total} summaries in {rounds} round(s)...", file=sys.stderr)
        final_summary = binary_merge(model, summaries)

    if not final_summary:
        die("binary merge returned an empty summary")

    print(f"git-ai: [merge] → {final_summary}", file=sys.stderr)

    # Step 4
    print("git-ai: [commit] generating commit message...", file=sys.stderr)
    raw_msg = generate_commit(model, final_summary)

    # Step 5 — validate with up to 3 retries
    msg = None
    candidate = raw_msg
    for attempt in range(1, 4):
        msg = validate_commit(candidate)
        if msg:
            break
        print(f"git-ai: attempt {attempt}/3 — invalid format, retrying...", file=sys.stderr)
        candidate = generate_commit(model, final_summary)

    if not msg:
        print("git-ai: could not produce a valid conventional commit after 3 attempts.", file=sys.stderr)
        print(f"git-ai: last raw output: {raw_msg}", file=sys.stderr)
        sys.exit(1)

    print(f"git-ai: → {msg}", file=sys.stderr)

    if dry_run:
        print(msg)
        return

    subprocess.run(["git", "commit", "-m", msg], check=True)

# ── dispatch ──────────────────────────────────────────────────────────────────

def main() -> None:
    args = sys.argv[1:]
    cmd = args[0] if args else ""

    if cmd == "commit":
        cmd_commit(args[1:])
    elif cmd in ("", "--help", "-h"):
        print("Usage: git ai <command> [options]", file=sys.stderr)
        print("", file=sys.stderr)
        print("Commands:", file=sys.stderr)
        print("  commit [--model <name>] [--dry-run]   Generate and apply a commit message", file=sys.stderr)
        print("", file=sys.stderr)
        print("Options:", file=sys.stderr)
        print("  --model, -m <name>   Ollama model to use (default: codellama)", file=sys.stderr)
        print("  --dry-run, -n        Print the message without committing", file=sys.stderr)
    else:
        die(f"unknown command '{cmd}' — run 'git ai --help'")


if __name__ == "__main__":
    main()
